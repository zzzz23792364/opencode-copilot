{
  "name": "@woxiaoniu/opencode-copilot",
  "version": "0.3.0",
  "description": "Feishu ↔ opencode TUI bidirectional bridge — share the same opencode session between your terminal and Feishu",
  "keywords": [
    "opencode",
    "feishu",
    "lark",
    "飞书",
    "bridge",
    "chatbot",
    "ai"
  ],
  "homepage": "https://github.com/zzzz23792364/opencode-copilot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zzzz23792364/opencode-copilot.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "opencode-copilot": "bin/opencode-copilot.mjs"
  },
  "files": [
    "src/",
    "bin/",
    "scripts/",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "npx tsx scripts/manage.ts start",
    "stop": "npx tsx scripts/manage.ts stop",
    "restart": "npx tsx scripts/manage.ts restart",
    "dev": "npx tsx watch src/index.ts",
    "status": "npx tsx scripts/manage.ts status",
    "test:e2e": "npx tsx scripts/e2e-test.ts",
    "test:ws": "npx tsx scripts/test-ws.ts"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.66.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^6.0.3"
  }
}
